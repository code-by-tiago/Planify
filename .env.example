# Planify | Environment example
# Copy this file to .env.local and fill real values locally.
# Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLANIFY_ADMIN_EMAIL=owner@example.com
PLANIFY_OWNER_EMAIL=owner@example.com
NEXT_PUBLIC_ADMIN_EMAIL=owner@example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (Google AI Studio / Gemini — faturação ativa obrigatória)
# Chave em https://aistudio.google.com/apikey (use Copiar — pode ser AIza... ou AQ....)
GEMINI_API_KEY=
# Modelo padrão (Flash) — usado na maioria das ferramentas
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# Modelo avançado (Pro) — reservado para tarefas pesadas no backend
GEMINI_MODEL_ADVANCED=gemini-2.5-pro
# Imagens de slides por IA: ligado automaticamente quando GEMINI_API_KEY existe.
# Desligue com SLIDE_AI_IMAGES=0 para usar só Wikimedia/stock.
# SLIDE_AI_IMAGES=1
# Cache de contexto Gemini (explícito + prefixo estático para cache implícito)
# Desligue com GEMINI_CONTEXT_CACHE=0
# GEMINI_CONTEXT_CACHE=1
# GEMINI_CONTEXT_CACHE_TTL_SECONDS=3600

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# Google OAuth — Drive + Classroom (guia: docs/google/CONFIGURAR-GOOGLE-CLOUD.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_OAUTH_STATE_SECRET=

# Slides — imagens reais (opcional; Wikimedia funciona sem chave)
UNSPLASH_ACCESS_KEY=

# Optional production
VERCEL_PROJECT_PRODUCTION_URL=

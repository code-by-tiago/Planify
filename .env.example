# Planify | Environment example
# Copy this file to .env.local and fill real values locally.
# Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WhatsApp comercial (B2B / landing /escolas) — DDI + DDD + número, só dígitos (ex.: 5511999999999)
NEXT_PUBLIC_WHATSAPP_COMMERCIAL=5511999999999
# Comma-separated for multiple owner/admin accounts (server + client)
PLANIFY_ADMIN_EMAIL=owner@example.com,admin2@example.com
PLANIFY_OWNER_EMAIL=owner@example.com
NEXT_PUBLIC_ADMIN_EMAIL=owner@example.com,admin2@example.com
# Cortesia ilimitada (sem créditos/cota diária; não concede admin)
PLANIFY_COURTESY_EMAILS=


# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (Google AI Studio / Gemini)
# Chave em https://aistudio.google.com/apikey (use Copiar — pode ser AIza... ou AQ....)
# Chave gratuita: cota limitada (RPM baixo); erros de indisponibilidade são comuns em pico.
# Produção: habilite faturamento pay-as-you-go no AI Studio — o tier gratuito continua
# aplicável, mas a cota sobe e a IA fica mais estável.
GEMINI_API_KEY=
# Modelo padrão (Flash) — usado na maioria das ferramentas
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# Modelo avançado — também usa Flash (único modelo habilitado)
GEMINI_MODEL_ADVANCED=gemini-2.5-flash
# Ilustrações de slides (Imagen 4) — mesma GEMINI_API_KEY
# Atalhos: imagen-4 | imagen-4-fast | imagen-4-ultra
# Ou ID completo: imagen-4.0-generate-001
IMAGEN_MODEL=imagen-4
# Imagens de slides por IA: ligado automaticamente quando GEMINI_API_KEY existe.
# Desligue com SLIDE_AI_IMAGES=0 para usar só Wikimedia/stock.
# SLIDE_AI_IMAGES=1
# Cache de contexto Gemini (explícito + prefixo estático para cache implícito)
# Desligue com GEMINI_CONTEXT_CACHE=0
# GEMINI_CONTEXT_CACHE=1
# GEMINI_CONTEXT_CACHE_TTL_SECONDS=3600

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# Google OAuth — Drive + Classroom (guia: docs/google/CONFIGURAR-GOOGLE-CLOUD.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_OAUTH_STATE_SECRET=

# Slides — imagens reais (opcional; Wikimedia funciona sem chave)
UNSPLASH_ACCESS_KEY=

# Banco de Questões — feeds JSON de instituições oficialmente autorizadas/licenciadas.
# Use o mesmo JSON no secret GitHub QUESTION_BANK_CURATED_FEEDS para a alimentação diária.
# Cada fonte precisa declarar URL HTTPS, licença e humanReviewed:true; fontes sem isso são bloqueadas.
# QUESTION_BANK_CURATED_FEEDS=[{"id":"parceiro-enem","name":"Instituição parceira","url":"https://dados.exemplo.br/questoes.json","license":"Licença de redistribuição","humanReviewed":true,"kind":"licensed","collection":"enem"}]
QUESTION_BANK_CURATED_FEEDS=[]

# Optional production
VERCEL_PROJECT_PRODUCTION_URL=

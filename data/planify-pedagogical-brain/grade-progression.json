{
  "version": "1.0.0",
  "levels": {
    "Educação Infantil": {
      "language": "oral, lúdica, sensorial e exploratória",
      "products": [
        "jogos",
        "rodas de conversa",
        "registros visuais",
        "brincadeiras orientadas"
      ],
      "avoid": [
        "prova formal",
        "texto longo"
      ]
    },
    "Fundamental 1": {
      "language": "clara, concreta, com exemplos próximos",
      "products": [
        "atividades guiadas",
        "recorte e colagem",
        "leitura curta",
        "desenho com legenda",
        "problemas simples"
      ],
      "avoid": [
        "abstração excessiva",
        "enunciado longo demais"
      ]
    },
    "Fundamental 2": {
      "language": "organizada, progressiva, com justificativa",
      "products": [
        "listas graduadas",
        "interpretação",
        "experimentos simples",
        "debates guiados",
        "sínteses"
      ],
      "avoid": [
        "questões infantis",
        "gabarito sem critério"
      ]
    },
    "Ensino Médio": {
      "language": "aprofundada, crítica e conceitual",
      "products": [
        "análise de texto/dados",
        "questões discursivas",
        "argumentação",
        "projetos",
        "provas contextualizadas"
      ],
      "avoid": [
        "conteúdo raso",
        "pergunta sem complexidade"
      ]
